# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you're executing a top-level application or tool, it is common to include it.
#   If you're building a library, check it in.
#Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock is generally recommended to be committed.
#poetry.lock

# pdm
#   Similar to Pipenv, pdm.lock is generally recommended to be committed.
.pdm-plugins/
.pdm-build/

# PEP 582; used by e.g. github.com/lincolnloop/layman and pdm
__pypackages__/

